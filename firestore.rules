rules_version = '2';

// Yosan — Firestore security rules.
//
// Roles:
//   guest  — not signed in (never reaches Firestore; the app runs local-only).
//   user   — any signed-in account. Syncs their budget + monthly results.
//   admin  — the single account below. Reads every account, manages users,
//            and writes app-wide config (feature flags + broadcast).
//
// Deploy this in the Firebase console (Firestore Database → Rules → paste →
// Publish) or with `firebase deploy --only firestore:rules`. See docs/ADMIN.md.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    // Admin is identified by email, which email/password tokens always carry —
    // so no custom claims are required.
    function isAdmin() {
      return signedIn() && request.auth.token.email == 'derekchu12@gmail.com';
    }

    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }

    // The current household is two people: Derek (admin) + Kelly. Kelly is
    // identified by email; both casings are allowed in case her account stored a
    // capitalized local part. `isCore()` is the pair that shares budgets/results.
    // When Household (#4) lands, replace this with real membership lookups.
    function isKelly() {
      return signedIn() && (
        request.auth.token.email == 'Kellyseadreams@gmail.com' ||
        request.auth.token.email == 'kellyseadreams@gmail.com'
      );
    }
    function isCore() { return isAdmin() || isKelly(); }

    // Budgets. Legacy fixed keys are locked to the people who actually use them,
    // so a future signed-up stranger can't read them:
    //   budgets/kelly — Kelly + Derek (Derek's app mirrors Kelly's budget)
    //   budgets/derek — Derek only (admin)
    // Any other key is treated as a per-user budget owned by that uid, ready for
    // public sign-up without another rules change.
    match /budgets/kelly { allow read, write: if isCore(); }
    match /budgets/derek { allow read, write: if isAdmin(); }
    match /budgets/{uid} { allow read, write: if isAdmin() || isOwner(uid); }

    // Monthly results summaries powering the shared Results view. The two
    // partners see each other's summaries; strangers see neither. Per-uid result
    // docs (future sign-ups) are owner-only + admin.
    match /results/kelly { allow read, write: if isCore(); }
    match /results/derek { allow read, write: if isCore(); }
    match /results/{uid} { allow read, write: if isAdmin() || isOwner(uid); }

    // User directory. A user may create/update ONLY their own profile and may
    // not grant themselves admin or un-pause themselves — those fields are
    // admin-only. The admin can read, write, and delete any account.
    match /users/{uid} {
      allow read:   if isAdmin() || isOwner(uid);
      allow create: if isAdmin() ||
        (isOwner(uid)
         && !request.resource.data.keys().hasAny(['disabled'])
         && request.resource.data.get('role', 'user') != 'admin');
      allow update: if isAdmin() ||
        (isOwner(uid)
         && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['disabled'])
         && request.resource.data.get('role', 'user') != 'admin');
      allow delete: if isAdmin();
    }

    // App config: feature flags + broadcast banner. World-readable so a broadcast
    // reaches even signed-out visitors; only the admin can change it.
    match /app/{doc} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // Households — two-person couples, summaries only (no category/transaction
    // data leaves your device). Kelly/Derek keep the built-in Results view; this
    // is the generic version for new couples.
    match /households/{hid} {
      allow read: if signedIn() && request.auth.uid in resource.data.members;
      allow create: if signedIn()
        && request.resource.data.adminUid == request.auth.uid
        && request.resource.data.members == [request.auth.uid];
      allow update: if signedIn() && (
        // Join: add ONLY yourself as the 2nd member; admin/code/name unchanged.
        (resource.data.members.size() == 1
          && request.resource.data.members == resource.data.members.concat([request.auth.uid])
          && request.resource.data.adminUid == resource.data.adminUid
          && request.resource.data.inviteCode == resource.data.inviteCode
          && request.resource.data.name == resource.data.name)
        // Admin edits (rename / remove a member).
        || (resource.data.adminUid == request.auth.uid)
        // Leave: remove ONLY yourself.
        || (request.auth.uid in resource.data.members
            && !(request.auth.uid in request.resource.data.members)
            && request.resource.data.members.size() == resource.data.members.size() - 1)
      );
      allow delete: if signedIn() && resource.data.adminUid == request.auth.uid;

      // Per-member summary (name, left, spent, saved). Members read all; you
      // write only your own.
      match /summaries/{uid} {
        allow read: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/households/$(hid)).data.members;
        allow write: if signedIn() && request.auth.uid == uid
          && request.auth.uid in get(/databases/$(database)/documents/households/$(hid)).data.members;
      }
    }

    // Invite codes → household id. Any signed-in user can redeem a code they were
    // given; only the household's admin can create/remove one.
    match /inviteCodes/{code} {
      allow read: if signedIn();
      allow create: if signedIn()
        && get(/databases/$(database)/documents/households/$(request.resource.data.householdId)).data.adminUid == request.auth.uid;
      allow delete: if signedIn()
        && get(/databases/$(database)/documents/households/$(resource.data.householdId)).data.adminUid == request.auth.uid;
    }
  }
}
